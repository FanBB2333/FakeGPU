#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

PYTHON_BIN="${FAKEGPU_PYTHON:-python3}"
SMOKE_BUILD_DIR="${BUILD_DIR:-build}"

usage() {
  cat <<'EOF'
Usage: ./ftest <suite>

Suites:
  smoke     Build + run basic C/Python checks (no torch required)
  cpu_sim   Build CPU simulation and validate cuBLAS ops
  python    Run PyTorch tests (requires torch)
  preflight_oom  Run fakecuda preflight pass/OOM report checks (requires torch)
  static_memory_validation  Capture ATen storage liveness and compare with real CUDA when available
  real_gpu_calibration  Calibrate real/passthrough/hybrid/fakecuda workloads on the detected GPU
  rtx3090ti_calibration  Deprecated alias for real_gpu_calibration
  llm       Run LLM inference smoke test (requires torch + transformers + local model)
  passthrough_parity  Compare direct vs passthrough LLM outputs (requires real GPU + local model)
  all       smoke + python

Env:
  BUILD_DIR=<path>       Build directory for smoke/python (default: build)
  FAKEGPU_PYTHON=<path>  Python interpreter used by Python-based suites (default: python3)
EOF
}

suite="${1:-}"
if [[ -z "${suite}" || "${suite}" == "-h" || "${suite}" == "--help" ]]; then
  usage
  exit 0
fi

build() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    cmake -S . -B "$SMOKE_BUILD_DIR" -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++
  else
    cmake -S . -B "$SMOKE_BUILD_DIR"
  fi
  cmake --build "$SMOKE_BUILD_DIR"
}

build_cpu_sim() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    cmake -S . -B build_cpu_sim -DENABLE_FAKEGPU_CPU_SIMULATION=ON -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++
  else
    cmake -S . -B build_cpu_sim -DENABLE_FAKEGPU_CPU_SIMULATION=ON
  fi
  cmake --build build_cpu_sim
}

compile_verify_preload() {
  local out="$SMOKE_BUILD_DIR/verify_preload"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    cc verification/verify_preload.c -o "$out"
  else
    cc verification/verify_preload.c -o "$out" -ldl
  fi
}

run_cpu_sim() {
  build_cpu_sim
  local out="build_cpu_sim/test_cublas_cpu_sim"
  c++ -std=c++17 verification/test_cublas_cpu_sim.cpp -o "$out" \
    -L build_cpu_sim -lcublas -lcudart -lcuda -lnvidia-ml
  FAKEGPU_REPORT_PATH="build_cpu_sim/fake_gpu_report.json" ./fgpu --build-dir build_cpu_sim "$out"
  "$PYTHON_BIN" verification/check_report.py --path build_cpu_sim/fake_gpu_report.json --expect-io --expect-flops

  if "$PYTHON_BIN" -c "import torch" >/dev/null 2>&1; then
    FAKEGPU_REPORT_PATH="build_cpu_sim/fake_gpu_report.json" ./fgpu --build-dir build_cpu_sim "$PYTHON_BIN" verification/test_cpu_sim_matmul.py
  else
    echo "torch not found in current python; skipping PyTorch matmul correctness check."
  fi
}

run_smoke() {
  build
  "$PYTHON_BIN" verification/check_library_boundaries.py --lib-dir "$SMOKE_BUILD_DIR"
  compile_verify_preload
  FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report.json" ./fgpu --build-dir "$SMOKE_BUILD_DIR" "$SMOKE_BUILD_DIR/verify_preload"
  "$PYTHON_BIN" verification/check_report.py --path "$SMOKE_BUILD_DIR/fake_gpu_report.json"
  FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report_multi_arch.json" ./fgpu --build-dir "$SMOKE_BUILD_DIR" --devices "gtx980,p100,p4,v100,t4,a100,a40,jetson-agx-orin-64gb,l4,h100,b200,b300,jetson-t5000,rtx-pro-5000-blackwell,gb10" "$PYTHON_BIN" verification/test_multi_arch_compute_units.py
  FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report_memory_types.json" ./fgpu --build-dir "$SMOKE_BUILD_DIR" "$PYTHON_BIN" verification/test_memory_types.py
}

run_python() {
  if ! "$PYTHON_BIN" -c "import torch" >/dev/null 2>&1; then
    echo "torch not found in current python; skipping PyTorch tests."
    return 0
  fi
  build
  if "$PYTHON_BIN" -c "import torch; raise SystemExit(0 if torch.version.cuda else 1)" >/dev/null 2>&1; then
    FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report.json" ./fgpu --build-dir "$SMOKE_BUILD_DIR" "$PYTHON_BIN" test/test_pytorch_basic.py
    "$PYTHON_BIN" verification/check_report.py --path "$SMOKE_BUILD_DIR/fake_gpu_report.json"
  else
    echo "PyTorch has no CUDA support; skipping native interception test."
  fi
  "$PYTHON_BIN" verification/test_fakecuda_profile_matrix.py
}

run_preflight_oom() {
  if ! "$PYTHON_BIN" -c "import torch" >/dev/null 2>&1; then
    echo "torch not found in current python; skipping preflight OOM tests."
    return 0
  fi

  local report_root="$SMOKE_BUILD_DIR/preflight_oom"
  rm -rf "$report_root"

  "$PYTHON_BIN" -m fakegpu preflight \
    --runtime fakecuda \
    --profile a100-1g \
    --device-count 1 \
    --stage forward \
    --report-dir "$report_root/pass" \
    --strict \
    -- "$PYTHON_BIN" verification/preflight_oom_probe.py --mode pass
  "$PYTHON_BIN" verification/check_preflight_report.py \
    --path "$report_root/pass/preflight_report.json" \
    --schema preflight_report.schema.json \
    --expect-status PASS_FIT \
    --expect-runtime fakecuda \
    --expect-device

  local rc=0
  "$PYTHON_BIN" -m fakegpu preflight \
    --runtime fakecuda \
    --profile a100-1g \
    --device-count 1 \
    --stage forward \
    --report-dir "$report_root/oom" \
    --strict \
    -- "$PYTHON_BIN" verification/preflight_oom_probe.py --mode oom || rc=$?
  if [[ "$rc" != "2" ]]; then
    echo "expected preflight OOM exit code 2, got $rc" >&2
    return 1
  fi
  "$PYTHON_BIN" verification/check_preflight_report.py \
    --path "$report_root/oom/preflight_report.json" \
    --schema preflight_report.schema.json \
    --expect-status FAIL_OOM \
    --expect-runtime fakecuda \
    --expect-device

  local matrix_elements=140000000
  local matrix_rc=0
  "$PYTHON_BIN" -m fakegpu preflight \
    --runtime fakecuda \
    --profile test-512m \
    --device-count 1 \
    --stage forward \
    --report-dir "$report_root/matrix-small" \
    --strict \
    -- "$PYTHON_BIN" verification/preflight_oom_probe.py --mode alloc --elements "$matrix_elements" || matrix_rc=$?
  if [[ "$matrix_rc" != "2" ]]; then
    echo "expected matrix small-profile OOM exit code 2, got $matrix_rc" >&2
    return 1
  fi
  "$PYTHON_BIN" verification/check_preflight_report.py \
    --path "$report_root/matrix-small/preflight_report.json" \
    --schema preflight_report.schema.json \
    --expect-status FAIL_OOM \
    --expect-runtime fakecuda \
    --expect-device

  "$PYTHON_BIN" -m fakegpu preflight \
    --runtime fakecuda \
    --profile a100 \
    --device-count 1 \
    --stage forward \
    --report-dir "$report_root/matrix-large" \
    --strict \
    -- "$PYTHON_BIN" verification/preflight_oom_probe.py --mode alloc --elements "$matrix_elements"
  "$PYTHON_BIN" verification/check_preflight_report.py \
    --path "$report_root/matrix-large/preflight_report.json" \
    --schema preflight_report.schema.json \
    --expect-status PASS_FIT \
    --expect-runtime fakecuda \
    --expect-device

  "$PYTHON_BIN" -m fakegpu preflight \
    --runtime fakecuda \
    --profile h100 \
    --device-count 1 \
    --stage forward \
    --report-dir "$report_root/matrix-h100" \
    --strict \
    -- "$PYTHON_BIN" verification/preflight_oom_probe.py --mode alloc --elements "$matrix_elements"
  "$PYTHON_BIN" verification/check_preflight_report.py \
    --path "$report_root/matrix-h100/preflight_report.json" \
    --schema preflight_report.schema.json \
    --expect-status PASS_FIT \
    --expect-runtime fakecuda \
    --expect-device
}

run_real_gpu_calibration() {
  local report_root="$SMOKE_BUILD_DIR/real_gpu_calibration"
  rm -rf "$report_root"

  "$PYTHON_BIN" verification/calibration_real_gpu.py \
    --out-dir "$report_root" \
    --build-dir "$SMOKE_BUILD_DIR"
  "$PYTHON_BIN" verification/check_real_gpu_calibration.py \
    --path "$report_root/calibration_real_gpu.json" \
    --allow-skip
}

run_static_memory_validation() {
  if ! "$PYTHON_BIN" -c "import torch" >/dev/null 2>&1; then
    echo "torch not found in current python; skipping static memory validation."
    return 0
  fi

  local report_root="$SMOKE_BUILD_DIR/static_memory_validation"
  rm -rf "$report_root"
  mkdir -p "$report_root"

  "$PYTHON_BIN" verification/static_memory_validation.py \
    --output "$report_root/static_memory_validation.json" \
    --max-underestimate-percent 5
  "$PYTHON_BIN" verification/check_static_memory_validation.py \
    --path "$report_root/static_memory_validation.json" \
    --allow-static-only \
    --max-underestimate-percent 5
}

run_llm() {
  if ! "$PYTHON_BIN" -c "import torch, transformers" >/dev/null 2>&1; then
    echo "torch/transformers not found in current python; skipping LLM smoke test."
    return 0
  fi

  local model_dir="$HOME/models/Qwen/Qwen2.5-0.5B-Instruct"
  if [[ ! -d "$model_dir" ]]; then
    echo "LLM model files not found at $model_dir; skipping LLM smoke test."
    return 0
  fi

  build
  local -a timeout_cmd=()
  if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 300)
  fi

  FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report_llm.json" \
    "${timeout_cmd[@]}" ./fgpu --build-dir "$SMOKE_BUILD_DIR" "$PYTHON_BIN" test/test_load_qwen2_5.py
  "$PYTHON_BIN" verification/check_report.py --path "$SMOKE_BUILD_DIR/fake_gpu_report_llm.json"
}

run_passthrough_parity() {
  if ! "$PYTHON_BIN" -c "import torch, transformers" >/dev/null 2>&1; then
    echo "torch/transformers not found in current python; skipping passthrough parity test."
    return 0
  fi

  local model_dir="$HOME/models/Qwen/Qwen2.5-0.5B-Instruct"
  if [[ ! -d "$model_dir" ]]; then
    echo "LLM model files not found at $model_dir; skipping passthrough parity test."
    return 0
  fi

  build
  local -a timeout_cmd=()
  if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 600)
  fi

  local baseline_out="$SMOKE_BUILD_DIR/passthrough_parity_baseline.pt"
  local passthrough_out="$SMOKE_BUILD_DIR/passthrough_parity_passthrough.pt"

  # Baseline: ensure FakeGPU preload env doesn't leak in.
  local rc=0
  env -u LD_PRELOAD -u DYLD_INSERT_LIBRARIES -u FAKEGPU_MODE -u FAKEGPU_OOM_POLICY \
    "${timeout_cmd[@]}" "$PYTHON_BIN" verification/passthrough_parity_qwen2_5.py \
      --out "$baseline_out" --model-dir "$model_dir" || rc=$?
  if [[ "$rc" != "0" ]]; then
    if [[ "$rc" == "2" ]]; then
      echo "CUDA not available; skipping passthrough parity test."
      return 0
    fi
    return "$rc"
  fi

  FAKEGPU_MODE=passthrough \
    FAKEGPU_REPORT_PATH="$SMOKE_BUILD_DIR/fake_gpu_report_passthrough_parity.json" \
    "${timeout_cmd[@]}" ./fgpu --mode passthrough --build-dir "$SMOKE_BUILD_DIR" \
      "$PYTHON_BIN" verification/passthrough_parity_qwen2_5.py \
      --out "$passthrough_out" --model-dir "$model_dir"

  "$PYTHON_BIN" verification/compare_parity_outputs.py \
    --baseline "$baseline_out" --passthrough "$passthrough_out"
}

case "$suite" in
  smoke)
    run_smoke
    ;;
  cpu_sim)
    run_cpu_sim
    ;;
  python)
    run_python
    ;;
  preflight_oom)
    run_preflight_oom
    ;;
  static_memory_validation)
    run_static_memory_validation
    ;;
  real_gpu_calibration)
    run_real_gpu_calibration
    ;;
  rtx3090ti_calibration)
    echo "rtx3090ti_calibration is deprecated; using real_gpu_calibration."
    run_real_gpu_calibration
    ;;
  llm)
    run_llm
    ;;
  passthrough_parity)
    run_passthrough_parity
    ;;
  all)
    run_smoke
    run_python
    ;;
  *)
    usage
    exit 2
    ;;
esac
